<?xml version="1.0"?>
<sdf version="1.6">
    <world name="maze_world">
        <plugin name="hunav_plugin" filename="libHuNavPlugin.so">
            <update_rate>100</update_rate>
            <robot_name>waffle_rl</robot_name>
            <use_gazebo_obs>true</use_gazebo_obs>
            <global_frame_to_publish>map</global_frame_to_publish>
            <use_navgoal_to_start>false</use_navgoal_to_start>
            <update_collision_cylinder>false</update_collision_cylinder>
            <navgoal_topic>goal_pose</navgoal_topic>
            <ignore_models>
                <model>ground_plane</model>
                <model>cafe</model>
                <model>agent1_collision</model>
            </ignore_models>
        </plugin>
        <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so">
            <update_rate>1.0</update_rate>
        </plugin>
        <physics type="ode">
            <max_step_size>0.001</max_step_size>
            <real_time_factor>0.2</real_time_factor>
            <real_time_update_rate>200</real_time_update_rate>
            <ode>
                <solver>
                    <type>quick</type>
                    <iters>150</iters>
                    <precon_iters>0</precon_iters>
                    <sor>1.3999999999999999</sor>
                    <use_dynamic_moi_rescaling>1</use_dynamic_moi_rescaling>
                </solver>
            </ode>
        </physics>
        <actor name="agent1">
            <pose>70.000000 70.000000 1.250000 0 0 0.000000</pose>
            <skin>
                <filename>elegant_man.dae</filename>
                <scale>1</scale>
            </skin>
            <animation name="no_active">
                <filename>07_01-walk.bvh</filename>
                <scale>1.0</scale>
            </animation>
            <animation name="active">
                <filename>07_01-walk.bvh</filename>
                <scale>1.0</scale>
                <interpolate_x>true</interpolate_x>
            </animation>
        </actor>
        <include>
            <uri>model://ground_plane</uri>
        </include>
        <include>
            <uri>model://sun</uri>
        </include>
