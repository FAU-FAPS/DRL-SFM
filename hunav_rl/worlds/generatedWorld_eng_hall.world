<?xml version="1.0" ?>
<sdf version="1.5">
    <world name="default">
        <plugin name="hunav_plugin" filename="libHuNavPlugin.so">
            <update_rate>100</update_rate>
            <robot_name>waffle_rl</robot_name>
            <use_gazebo_obs>true</use_gazebo_obs>
            <global_frame_to_publish>map</global_frame_to_publish>
            <use_navgoal_to_start>false</use_navgoal_to_start>
            <update_collision_cylinder>false</update_collision_cylinder>
            <navgoal_topic>goal_pose</navgoal_topic>
            <ignore_models>
                <model>ground_plane</model>
                <model>cafe</model>
                <model>agent1_0_collision</model>
                <model>agent1_1_collision</model>
