                <model>agent6_3_collision</model>
            </ignore_models>
        </plugin>
        <physics type="ode">
            <max_step_size>0.001</max_step_size>
            <real_time_factor>0.2</real_time_factor>
            <real_time_update_rate>200</real_time_update_rate>
            <ode>
                <solver>
                    <type>quick</type>
                    <iters>150</iters>
                    <precon_iters>0</precon_iters>
                    <sor>1.3999999999999999</sor>
                    <use_dynamic_moi_rescaling>1</use_dynamic_moi_rescaling>
                </solver>
            </ode>
        </physics>
        <actor name="agent1_0">
            <pose>1.000000 10.000000 1.250000 0 0 0.000000</pose>
            <skin>
                <filename>elegant_man.dae</filename>
